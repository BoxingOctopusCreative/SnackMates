# ── API ──────────────────────────────────────────────────────────────────────
# Optional TOML config file (see api/config.example.toml). Env vars override file values.
# CONFIG_FILE=./config.toml
API_PORT=8080
API_BASE_URL=http://localhost:8080
WEB_ORIGIN=http://localhost:3000
JWT_SECRET=change-me-in-production-use-a-long-random-string

# ── Sentry (optional) ────────────────────────────────────────────────────────
# SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
# SENTRY_ENVIRONMENT=development

# ── Postgres ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgres://snackmates:snackmates@localhost:5432/snackmates?sslmode=disable
# MIGRATIONS_DIR=migrations

# ── Valkey ───────────────────────────────────────────────────────────────────
VALKEY_URL=redis://localhost:6379/0

# ── Meilisearch ──────────────────────────────────────────────────────────────
MEILISEARCH_URL=http://localhost:7700
MEILISEARCH_API_KEY=snackmates-dev-master-key

# ── S3-compatible object storage (Cloudflare R2, MinIO, etc.) ────────────────
# Local dev defaults to MinIO from docker compose. Production uses Cloudflare R2.
S3_ENDPOINT=http://localhost:9000
# R2: use "auto". MinIO/local: us-east-1 is fine.
S3_REGION=auto
S3_ACCESS_KEY=snackmates
S3_SECRET_KEY=snackmates-dev
S3_CLIENT_ASSETS_BUCKET=client-assets
S3_STATIC_ASSETS_BUCKET=static-assets
# Path-style URLs (recommended for R2 presigned URLs). Virtual-hosted if false.
S3_USE_PATH_STYLE=true
# Optional public URL base override (R2 custom domain, r2.dev, or CDN). Leave empty to derive from S3_ENDPOINT.
# S3_PUBLIC_BASE_URL=https://static.example.com
# Presign private object URLs (recommended for R2 private buckets). Set false for public MinIO dev buckets.
S3_PRESIGN_PRIVATE_OBJECTS=true
S3_PRESIGN_EXPIRY_SECONDS=3600

# Production R2 example:
# S3_ENDPOINT=https://<account_id>.r2.cloudflarestorage.com
# S3_REGION=auto
# S3_ACCESS_KEY=
# S3_SECRET_KEY=

# ── Email ────────────────────────────────────────────────────────────────────
# Provider: smtp (Mailpit in dev) or mailgun (production)
EMAIL_PROVIDER=smtp
EMAIL_FROM=noreply@snackmates.local
# SMTP (local dev via Mailpit)
SMTP_HOST=localhost
SMTP_PORT=1025
# Mailgun (production)
# EMAIL_PROVIDER=mailgun
# MAILGUN_API_KEY=
# MAILGUN_DOMAIN=mg.example.com
# MAILGUN_API_BASE_URL=https://api.mailgun.net
# EU region: MAILGUN_API_BASE_URL=https://api.eu.mailgun.net

# ── Discord OAuth ───────────────────────────────────────────────────────────
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_REDIRECT_URI=http://localhost:8080/api/v1/auth/discord/callback

# ── WebAuthn ─────────────────────────────────────────────────────────────────
WEBAUTHN_RP_ID=localhost
WEBAUTHN_RP_ORIGIN=http://localhost:3000
WEBAUTHN_RP_NAME=SnackMates

# ── Anthropic (primary AI-assisted snack search) ─────────────────────────────
ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# ── OVH AI Endpoints (fallback LLM for snack search) ─────────────────────────
# https://www.ovhcloud.com/en/public-cloud/ai-endpoints/catalog/mistral-nemo-instruct-2407/
OVH_AI_ENDPOINTS_ACCESS_TOKEN=
# OVH_AI_MODEL=Mistral-Nemo-Instruct-2407
# OVH_AI_BASE_URL=https://oai.endpoints.kepler.ai.cloud.ovh.net/v1

# OPENFOODFACTS_SEARCH_URL=https://search.openfoodfacts.org
# OPENFOODFACTS_BASE_URL=https://ca.openfoodfacts.org

# ── Next.js ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8080
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Unsplash (splash page backgrounds). Create a free app at https://unsplash.com/developers
UNSPLASH_ACCESS_KEY=
# Public base URL for first-party static assets (legal markdown, branding). Defaults to production CDN.
# STATIC_ASSETS_BASE_URL=https://assets.snackmates.food
# Local MinIO example: STATIC_ASSETS_BASE_URL=http://localhost:9000/static-assets
